run = "bash start.sh"
modules = ["nodejs-20"]

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[deployment]
run = ["bash", "start.sh"]
deploymentTarget = "cloudrun"
build = ["bash", "-c", "cd client && npm install && npm run build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
